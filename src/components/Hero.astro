---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { heroImage as localHeroImage } from '../config/images';

// 建議之後換成你工作的側拍照
const PLACEHOLDER = 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=1200&q=80';

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  // 修改預設值，直接對標你的文案
  topper = 'AI 時代，判斷力才是你唯一的護城河',
  heading = '我是比利陳',
  description = '這裡記錄我如何用 AI 改善工作流程，並用思維邏輯建立不可替代的專業地位。',
  ctaLabel = '加入 Line 群組',
  ctaHref = '你的Line群組連結',
  secondaryLabel = '訂閱電子報',
  secondaryHref = '你的電子報連結', // 例如 Kit 頁面
  imageSrc = localHeroImage ?? PLACEHOLDER,
  imageAlt = '比利陳 - 行銷實戰與 AI 工作流實踐者',
} = Astro.props;
---

<section class="relative overflow-hidden bg-background py-12 sm:py-16 md:py-20 lg:py-24">
  <div class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12">

    <div class="order-2 space-y-5 lg:order-1 lg:space-y-6">
      {topper && (
        <span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent">
          {topper}
        </span>
      )}

      <h1
        class="font-heading text-display font-bold uppercase leading-none tracking-tight text-text"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-lg text-lead text-text-muted leading-relaxed">
        {description}
      </p>

      <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4">
        {/* 主按鈕：加入 Line 群組 */}
        <a
          href={ctaHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {ctaLabel}
        </a>
        
        {/* 副按鈕：訂閱電子報 */}
        <a
          href={secondaryHref}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[44px] items-center justify-center rounded-md border-2 border-primary px-6 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {secondaryLabel}
        </a>
      </div>

      {/* 移除原本的電話連結，改為展示 Slogan 或小提示 */}
      <p class="pt-1 text-sm font-medium text-text-muted">
        讓我們運用頂尖 AI 工具提升行銷效率
      </p>
    </div>

    <div
      class="relative order-1 overflow-hidden rounded-lg shadow-xl aspect-4/3 lg:order-2"
      transition:name="hero-image"
    >
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={800}
        height={600}
        loading="eager"
        decoding="async"
        class="size-full object-cover"
      />
    </div>
  </div>
</section>